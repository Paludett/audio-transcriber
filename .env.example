# faster-whisper model size: tiny, base, small, medium, large-v3
# "small" is the safe default for 4GB VRAM. "medium" with int8 still fits.
# "large-v3" will probably exceed 4GB; use at your own risk.
WHISPER_MODEL=small

# Quantization type. int8_float16 is lighter on VRAM while keeping good quality.
WHISPER_COMPUTE_TYPE=int8_float16

# Device: cuda or cpu. If cuda fails at startup (for example OOM), it falls back to cpu automatically.
WHISPER_DEVICE=cuda

# Default forced transcription language (avoids automatic detection and runs faster).
WHISPER_LANGUAGE=en

# Maximum upload size in bytes (default: 100MB)
MAX_UPLOAD_SIZE_BYTES=104857600

# YouTube transcription: max video duration accepted, in seconds (default: 2h).
# Also protects against livestreams (which report no/zero duration).
YOUTUBE_MAX_DURATION_SECONDS=7200

# YouTube transcription: max bytes to download for the Whisper-fallback audio track
# (backstop in case reported duration is wrong; default: 500MB).
YOUTUBE_MAX_DOWNLOAD_BYTES=524288000

# Whether YouTube's auto-generated (ASR) captions count as usable "official" captions.
# If false, only human-made captions skip Whisper; auto captions fall back to Whisper.
YOUTUBE_ACCEPT_AUTO_CAPTIONS=true
